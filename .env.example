PORT=5000

# MongoDB Connection String
# Option 1 – MongoDB Atlas (cloud, free tier — recommended if no local MongoDB)
# Get your string from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nexus_db
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/nexus_db

# Option 2 – Local MongoDB (only if MongoDB is installed on your machine)
# MONGO_URI=mongodb://localhost:27017/nexus_db

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the Express backend. Must start with VITE_ to be exposed to the browser.
VITE_API_BASE_URL=http://localhost:5000
